---
import Badge from '../ui/Badge.astro';

export interface Props {
  title: string;
  session?: number;
  week: number;
  weekTheme: string;
  duration: string;
  objectives: string[];
  isRetro?: boolean;
}

const { title, session, week, weekTheme, duration, objectives, isRetro = false } = Astro.props;
---

<header class="session-header">
  <div class="session-header__meta">
    <div class="session-header__badges">
      <Badge variant="week">Week {week}: {weekTheme}</Badge>
      <Badge variant="duration">{duration}</Badge>
    </div>
  </div>

  <div class="session-header__title-row">
    {!isRetro && session && (
      <Badge variant="session">{session}</Badge>
    )}
    <h1 class="session-header__title">{title}</h1>
  </div>

  {objectives.length > 0 && (
    <div class="session-header__objectives">
      <h2 class="session-header__objectives-heading">Learning Objectives</h2>
      <ul class="session-header__objectives-list">
        {objectives.map((obj) => (
          <li class="session-header__objective">
            <span class="session-header__objective-check" aria-hidden="true">✓</span>
            <span>{obj}</span>
          </li>
        ))}
      </ul>
    </div>
  )}
</header>

<style>
  .session-header {
    padding: var(--space-10) var(--content-padding) var(--space-8);
    max-width: var(--content-max-width);
    margin: 0 auto;
    border-bottom: var(--border-width) solid var(--color-border);
    margin-bottom: var(--space-8);
  }

  .session-header__meta {
    margin-bottom: var(--space-4);
  }

  .session-header__badges {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .session-header__title-row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .session-header__title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-semibold);
    color: var(--color-neutral-900);
    line-height: var(--leading-tight);
    margin: 0;
  }

  .session-header__objectives {
    background-color: var(--color-bg-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-6);
  }

  .session-header__objectives-heading {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-neutral-500);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 var(--space-3);
  }

  .session-header__objectives-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .session-header__objective {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-neutral-700);
    margin-bottom: 0;
  }

  .session-header__objective-check {
    flex-shrink: 0;
    color: var(--color-success);
    font-weight: var(--weight-bold);
    margin-top: 1px;
  }
</style>
