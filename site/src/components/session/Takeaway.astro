---
// No props — slot-only component for session takeaway banner
---

<div class="takeaway">
  <div class="takeaway__inner">
    <span class="takeaway__icon" aria-hidden="true">🎯</span>
    <div class="takeaway__content">
      <strong class="takeaway__label">Session Takeaway</strong>
      <div class="takeaway__body">
        <slot />
      </div>
    </div>
  </div>
</div>

<style>
  .takeaway {
    border-left: 4px solid var(--color-success);
    background-color: #f0fdf4;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: var(--space-5) var(--space-6);
    margin-top: var(--space-8);
    margin-bottom: var(--space-6);
  }

  .takeaway__inner {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .takeaway__icon {
    font-size: var(--text-xl);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .takeaway__content {
    flex: 1;
    min-width: 0;
  }

  .takeaway__label {
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: #065f46;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-2);
  }

  .takeaway__body {
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-neutral-800);
    line-height: var(--leading-normal);
  }

  .takeaway__body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
