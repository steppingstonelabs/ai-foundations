---
import { getSessionsByWeek } from '../../lib/sessions';
import { WEEKS } from '../../lib/constants';
import SidebarWeekGroup from './SidebarWeekGroup.astro';
import MobileMenuToggle from './MobileMenuToggle.astro';

export interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;
const sessionsByWeek = await getSessionsByWeek();
---

<div class="sidebar-overlay" id="sidebar-overlay"></div>

<aside class="sidebar" id="sidebar">
  <div class="sidebar__header">
    <a href={import.meta.env.BASE_URL} class="sidebar__logo">
      <span class="sidebar__logo-mark">AI</span>
      <span class="sidebar__logo-text">Skills Workshop</span>
    </a>
    <MobileMenuToggle />
  </div>

  <div class="sidebar__nav">
    {WEEKS.map((week) => {
      const sessions = sessionsByWeek.get(week.number) ?? [];
      return (
        <SidebarWeekGroup
          week={week.number}
          theme={week.theme}
          sessions={sessions}
          currentSlug={currentSlug}
        />
      );
    })}
  </div>

  <div class="sidebar__footer">
    <a href={import.meta.env.BASE_URL} class="sidebar__home-link">← Curriculum Overview</a>
  </div>
</aside>

<style>
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 40;
  }

  .sidebar {
    width: var(--sidebar-width);
    height: 100vh;
    background-color: var(--color-bg-sidebar);
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
    overflow: hidden;
    flex-shrink: 0;
  }

  .sidebar__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-5) var(--space-4);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    flex-shrink: 0;
  }

  .sidebar__logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--color-neutral-100);
  }

  .sidebar__logo:hover {
    text-decoration: none;
  }

  .sidebar__logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background-color: var(--color-primary-600);
    color: white;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    border-radius: var(--radius-md);
    letter-spacing: 0.05em;
  }

  .sidebar__logo-text {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-neutral-200);
  }

  .sidebar__nav {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-2) 0;
    scrollbar-width: thin;
    scrollbar-color: var(--color-neutral-700) transparent;
  }

  .sidebar__footer {
    padding: var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    flex-shrink: 0;
  }

  .sidebar__home-link {
    font-size: var(--text-xs);
    color: var(--color-neutral-500);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .sidebar__home-link:hover {
    color: var(--color-neutral-300);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      left: 0;
      top: 0;
      z-index: 50;
      transform: translateX(-100%);
      transition: transform var(--transition-base);
      box-shadow: var(--shadow-lg);
    }

    .sidebar--open {
      transform: translateX(0);
    }

    .sidebar--open ~ .sidebar-overlay,
    .sidebar-overlay.active {
      display: block;
    }
  }
</style>

<script>
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');

  overlay?.addEventListener('click', () => {
    sidebar?.classList.remove('sidebar--open');
    overlay.classList.remove('active');
  });
</script>
