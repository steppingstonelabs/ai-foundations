---
import SidebarLink from './SidebarLink.astro';

export interface SessionEntry {
  slug: string;
  data: {
    session?: number;
    title: string;
    duration: string;
    isRetro: boolean;
  };
}

export interface Props {
  week: number;
  theme: string;
  sessions: SessionEntry[];
  currentSlug?: string;
}

const { week, theme, sessions, currentSlug } = Astro.props;
---

<div class="week-group">
  <div class="week-group__header">
    <span class="week-group__label">Week {week}</span>
    <span class="week-group__theme">{theme}</span>
  </div>
  <nav class="week-group__sessions">
    {sessions.map((session) => (
      <SidebarLink
        href={`${import.meta.env.BASE_URL}sessions/${session.slug}`}
        sessionNumber={session.data.session}
        title={session.data.title}
        duration={session.data.duration}
        isActive={currentSlug === session.slug}
        isRetro={session.data.isRetro}
      />
    ))}
  </nav>
</div>

<style>
  .week-group {
    margin-bottom: var(--space-4);
  }

  .week-group__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-4) var(--space-2);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin-top: var(--space-2);
  }

  .week-group__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-primary-400);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .week-group__theme {
    font-size: var(--text-xs);
    color: var(--color-neutral-500);
    line-height: var(--leading-normal);
  }

  .week-group__sessions {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
</style>
