---
export interface Props {
  href: string;
  sessionNumber?: number;
  title: string;
  duration: string;
  isActive?: boolean;
  isRetro?: boolean;
}

const { href, sessionNumber, title, duration, isActive = false, isRetro = false } = Astro.props;
---

<a
  href={href}
  class:list={['sidebar-link', { 'sidebar-link--active': isActive }]}
  aria-current={isActive ? 'page' : undefined}
>
  <span class="sidebar-link__number">
    {isRetro ? '✦' : sessionNumber}
  </span>
  <span class="sidebar-link__title">{title}</span>
  <span class="sidebar-link__duration">{duration}</span>
</a>

<style>
  .sidebar-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-4);
    text-decoration: none;
    color: var(--color-neutral-400);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    border-left: 3px solid transparent;
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast),
      border-color var(--transition-fast);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .sidebar-link:hover {
    color: var(--color-neutral-200);
    background-color: rgba(255, 255, 255, 0.05);
    text-decoration: none;
  }

  .sidebar-link--active {
    color: var(--color-neutral-100);
    background-color: rgba(255, 255, 255, 0.08);
    border-left-color: var(--color-primary-400);
  }

  .sidebar-link__number {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    background-color: var(--color-neutral-700);
    color: var(--color-neutral-300);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-full);
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .sidebar-link--active .sidebar-link__number {
    background-color: var(--color-primary-600);
    color: white;
  }

  .sidebar-link__title {
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sidebar-link__duration {
    flex-shrink: 0;
    font-size: var(--text-xs);
    color: var(--color-neutral-600);
    background-color: var(--color-neutral-800);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-full);
  }

  .sidebar-link--active .sidebar-link__duration {
    color: var(--color-neutral-400);
    background-color: rgba(255, 255, 255, 0.1);
  }
</style>
