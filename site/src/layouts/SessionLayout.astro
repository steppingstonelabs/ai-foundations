---
import BaseLayout from './BaseLayout.astro';
import SessionHeader from '../components/session/SessionHeader.astro';

export interface Props {
  session: {
    title: string;
    session?: number;
    week: number;
    weekTheme: string;
    duration: string;
    objectives: string[];
    coreTeachingMoment: string;
    takeaway: string;
    status: 'complete' | 'in-progress' | 'planned';
    order: number;
    isRetro: boolean;
  };
  prev?: { slug: string; data: { title: string; session?: number } } | null;
  next?: { slug: string; data: { title: string; session?: number } } | null;
  currentSlug?: string;
}

const { session, prev, next, currentSlug } = Astro.props;
---

<BaseLayout
  title={`Session ${session.session ?? ''}: ${session.title} — AI Skills Workshop`}
  description={session.takeaway}
  currentSlug={currentSlug}
>
  <article class="session-page">
    <SessionHeader
      title={session.title}
      session={session.session}
      week={session.week}
      weekTheme={session.weekTheme}
      duration={session.duration}
      objectives={session.objectives}
    />

    <div class="session-body">
      <slot />
    </div>

    <footer class="session-footer">
      <nav class="session-nav" aria-label="Session navigation">
        <div class="session-nav__prev">
          {prev && (
            <a href={`/sessions/${prev.slug}`} class="session-nav__link session-nav__link--prev">
              <span class="session-nav__direction">← Previous</span>
              <span class="session-nav__title">{prev.data.title}</span>
            </a>
          )}
        </div>
        <div class="session-nav__next">
          {next && (
            <a href={`/sessions/${next.slug}`} class="session-nav__link session-nav__link--next">
              <span class="session-nav__direction">Next →</span>
              <span class="session-nav__title">{next.data.title}</span>
            </a>
          )}
        </div>
      </nav>
    </footer>
  </article>
</BaseLayout>

<style>
  .session-page {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding-bottom: var(--space-16);
  }

  .session-body {
    padding: 0 var(--content-padding);
    line-height: var(--leading-relaxed);
  }

  .session-body :global(h2) {
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .session-footer {
    padding: var(--space-8) var(--content-padding) 0;
    border-top: var(--border-width) solid var(--color-border);
    margin-top: var(--space-12);
  }

  .session-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .session-nav__prev {
    justify-self: start;
  }

  .session-nav__next {
    justify-self: end;
    text-align: right;
  }

  .session-nav__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-4);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition:
      border-color var(--transition-fast),
      background-color var(--transition-fast);
    max-width: 260px;
  }

  .session-nav__link:hover {
    border-color: var(--color-primary-400);
    background-color: var(--color-primary-50);
    text-decoration: none;
  }

  .session-nav__direction {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: var(--weight-medium);
  }

  .session-nav__title {
    font-size: var(--text-sm);
    color: var(--color-neutral-800);
    font-weight: var(--weight-medium);
  }
</style>
