# ============================================================
# AI Basics Workshop Site — Environment Variables
# ============================================================
# Copy this file to .env and fill in values for local development.
# Never commit .env to version control.
# ============================================================

# The canonical URL of the deployed site.
# Used by Astro for sitemap generation, canonical <link> tags, etc.
# Default (local dev): http://localhost:4321
# Production: https://workshop.steppingstonelabs.com
SITE_URL=https://workshop.steppingstonelabs.com

# ---- Netlify (set in Netlify UI or via `netlify env:set`) ----
# NETLIFY_AUTH_TOKEN — personal access token for CI deploys
# NETLIFY_SITE_ID   — the UUID of your Netlify site
# (These are only required in CI/CD; do NOT put real values here.)

# ---- Optional analytics / tracking ----
# PUBLIC_PLAUSIBLE_DOMAIN=workshop.steppingstonelabs.com
