{
  "$ref": "#/definitions/sessions",
  "definitions": {
    "sessions": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "session": {
          "type": "number",
          "minimum": 1,
          "maximum": 17
        },
        "week": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "weekTheme": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "objectives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "coreTeachingMoment": {
          "type": "string"
        },
        "takeaway": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "complete",
            "in-progress",
            "planned"
          ],
          "default": "complete"
        },
        "order": {
          "type": "number"
        },
        "isRetro": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "week",
        "weekTheme",
        "duration",
        "objectives",
        "coreTeachingMoment",
        "takeaway",
        "order"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}